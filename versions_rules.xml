<?xml version="1.0" encoding="UTF-8"?>
<!--
    Rules file for org.codehaus.mojo:versions-maven-plugin.

    Defines version comparator and ignored update patterns for dependencies and
    plugins that should not be automatically upgraded to certain release lines.

    Reference: https://www.mojohaus.org/versions/versions-maven-plugin/version-rules.html
-->
<ruleset xmlns="https://www.mojohaus.org/VERSIONS/RULE/3.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://www.mojohaus.org/VERSIONS/RULE/3.0.0 https://www.mojohaus.org/versions/versions-model/xsd/rule-3.0.0.xsd">

    <!-- Ignore milestone and release-candidate versions for all artifacts by default -->
    <ignoreVersions>
        <ignoreVersion type="regex">.*[-_\.](alpha|Alpha|ALPHA|beta|Beta|BETA|rc|RC|cr|CR|milestone|M|m)[0-9]*.*
        </ignoreVersion>
        <ignoreVersion type="regex">.*\..*\..*\..*</ignoreVersion>
    </ignoreVersions>

    <rules>
        <!-- maven-compiler-plugin: stay on 3.x stable (4.x is still beta) -->
        <rule groupId="org.apache.maven.plugins" artifactId="maven-compiler-plugin">
            <ignoreVersions>
                <ignoreVersion type="regex">4\..*</ignoreVersion>
            </ignoreVersions>
        </rule>

        <!-- maven-jar-plugin: stay on 3.x stable (4.x is still beta) -->
        <rule groupId="org.apache.maven.plugins" artifactId="maven-jar-plugin">
            <ignoreVersions>
                <ignoreVersion type="regex">4\..*</ignoreVersion>
            </ignoreVersions>
        </rule>

        <!-- maven-source-plugin: stay on 3.x stable (4.x is still beta) -->
        <rule groupId="org.apache.maven.plugins" artifactId="maven-source-plugin">
            <ignoreVersions>
                <ignoreVersion type="regex">4\..*</ignoreVersion>
            </ignoreVersions>
        </rule>

        <!-- JUnit: do not upgrade to milestone/RC releases automatically -->
        <rule groupId="org.junit" artifactId="junit-bom">
            <ignoreVersions>
                <ignoreVersion type="regex">.*-M[0-9]+</ignoreVersion>
                <ignoreVersion type="regex">.*-RC[0-9]+</ignoreVersion>
            </ignoreVersions>
        </rule>
        <rule groupId="org.junit.jupiter">
            <ignoreVersions>
                <ignoreVersion type="regex">.*-M[0-9]+</ignoreVersion>
                <ignoreVersion type="regex">.*-RC[0-9]+</ignoreVersion>
            </ignoreVersions>
        </rule>
    </rules>

</ruleset>
